# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=cve
POSTGRES_PASSWORD=<changeme>
POSTGRES_DB=cve_ingest

# ── pgAdmin (development only) ────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@cve.ingest
PGADMIN_DEFAULT_PASSWORD=<changeme>

# ── Hasura GraphQL Engine ─────────────────────────────────────────────────────
# Admin secret for Hasura console and admin API access.
HASURA_ADMIN_SECRET=<changeme>
# JWT signing key for read-only GraphQL tokens (used by `create-token` command).
# Generate: openssl rand -hex 32
# Leave empty to fall back to a non-functional placeholder (tokens won't validate).
HASURA_JWT_SECRET=

# ── NVD API Key (optional, but strongly recommended for CPE sync) ─────────────
# Without key: 5 req/30s → ~17 min for full CPE download
# With    key: 50 req/30s → ~2  min for full CPE download
# Free key: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── Comparison tools (optional, used by tools/osv_compare/*) ──────────────────
# GraphQL endpoint + read-only token used by the OSV/Trivy comparison scripts.
CVEDB_GRAPHQL_URL=http://localhost:8080/v1/graphql
CVEDB_GRAPHQL_TOKEN=

# ── MCP server (optional) ─────────────────────────────────────────────────────
# Only needed if you enable the commented-out `mcp` service in docker-compose.prod.yml.
# Bearer token MCP clients must present. Generate: openssl rand -hex 32
MCP_AUTH_TOKEN=
# Auth to Hasura is reused: the MCP server mints a read-only token from HASURA_JWT_SECRET
# (above). Alternatively, pin a pre-minted read-only token here:
# GRAPHQL_TOKEN=

# ── HTTP Proxy (optional, needed in corporate environments) ───────────────────
# Used by git clone, wget, httpx for all sync commands.
# Leave empty if no proxy is needed.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres
